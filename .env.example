# Next.js runtime
NODE_ENV=production
WEB_PORT=3000

# Matomo web
MATOMO_PORT=8080
MATOMO_IMAGE=matomo:5-apache

# Matomo app integration (used by Next.js SSR tracking)
MATOMO_URL=http://matomo
MATOMO_SITE_ID=1
MATOMO_TOKEN_AUTH=

# Matomo database
MATOMO_DB_IMAGE=mariadb:11
MATOMO_DB_HOST=matomo-db
MATOMO_DB_NAME=matomo
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=change_me
MATOMO_DB_ROOT_PASSWORD=change_root_password
MATOMO_DB_TABLES_PREFIX=matomo_
