{
  "kind": "collectionType",
  "collectionName": "sponsors",
  "info": {
    "singularName": "sponsor",
    "pluralName": "sponsors",
    "displayName": "Sponsor",
    "description": "Sponsor configuration for the public web sponsor engine"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "sponsor": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "alt": {
      "type": "string",
      "required": true
    },
    "url": {
      "type": "string",
      "required": true
    },
    "selector": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "tokenMultiplier": {
      "type": "integer",
      "required": true,
      "default": 100,
      "min": 1
    },
    "sortOrder": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  }
}
